AI_TRADE_API_TIMEOUT_MS=8000
# Legacy code is audit/rollback only. Never set YES while BullMQ execution is enabled.
LEGACY_AI_TRADE_ALLOW_NEW=NO
# Opt-in only on an isolated test/staging database with at least 20,000 synthetic users.
AI_TRADE_LOAD_TEST_CONFIRM=NO
SALARY_TIME_ZONE=Asia/Kolkata
SALARY_QUEUE_CONCURRENCY=20
SALARY_ENQUEUE_BATCH_SIZE=500
SALARY_MAX_RETRIES=8

# Automatic USDT/BEP20 withdrawals. Keep false until audit and limited-value testing pass.
WITHDRAWAL_AUTOMATION_ENABLED=false
WITHDRAWAL_NETWORK=USDT_BEP20
WITHDRAWAL_CHAIN_ID=56
WITHDRAWAL_TOKEN_CONTRACT=
WITHDRAWAL_TOKEN_DECIMALS=18
WITHDRAWAL_REQUIRED_CONFIRMATIONS=12
WITHDRAWAL_RPC_URL=
WITHDRAWAL_SIGNER_TYPE=KEYSTORE
# Worker-only secret settings. Never use NEXT_PUBLIC_* and do not expose these to the web process.
WITHDRAWAL_KEYSTORE_PATH=
WITHDRAWAL_KEYSTORE_PASSWORD=
# Temporary worker-only fallback; prefer KMS/Vault or encrypted keystore.
WITHDRAWAL_PRIVATE_KEY=
WITHDRAWAL_NATIVE_GAS_RESERVE_WEI=0
WITHDRAWAL_CONFIRMATION_POLL_MS=15000
WITHDRAWAL_WORKER_CONCURRENCY=1
WITHDRAWAL_MAX_ATTEMPTS=5
WITHDRAWAL_BLOCKED_ADDRESSES=
WITHDRAWAL_RAPID_REQUEST_WINDOW_SECONDS=60
AUTO_WITHDRAW_MIN_AMOUNT=10
AUTO_WITHDRAW_MAX_PER_TX=500
AUTO_WITHDRAW_MAX_PER_USER_DAILY=1000
AUTO_WITHDRAW_MAX_GLOBAL_DAILY=10000
