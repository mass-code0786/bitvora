REDIS_URL=redis://127.0.0.1:6379
AI_TRADE_QUEUE_CONCURRENCY=20
AI_TRADE_ENQUEUE_BATCH_SIZE=500
AI_TRADE_SETTLEMENT_CONCURRENCY=20
AI_TRADE_MAX_RETRIES=8
