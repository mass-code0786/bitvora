generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  USER
  ADMIN
}

enum IdempotencyStatus {
  PENDING
  COMPLETED
  FAILED
}

enum AiBotSubscriptionStatus {
  ACTIVE
  EXPIRED
}

enum BannerStatus {
  DRAFT
  ACTIVE
  INACTIVE
  EXPIRED
}

enum ReferralDistributionStatus {
  CREATED
  NO_PAYOUT
}

model User {
  id                          String                       @id @default(cuid())
  uid                         String                       @unique @db.VarChar(8)
  email                       String                       @unique
  passwordHash                String
  name                        String
  role                        Role                         @default(USER)
  sponsorId                   String?
  sponsorUid                  String?                      @db.VarChar(8)
  emailVerified               DateTime?
  image                       String?
  createdAt                   DateTime                     @default(now())
  updatedAt                   DateTime                     @updatedAt
  timezone                    String                       @default("UTC")
  country                     String?
  countryName                 String?
  countryCode                 String?                      @db.VarChar(2)
  sponsor                     User?                        @relation("UserSponsor", fields: [sponsorId], references: [id], onDelete: SetNull)
  directReferrals             User[]                       @relation("UserSponsor")
  accounts                    Account[]
  sessions                    Session[]
  idempotencyRecords          IdempotencyRecord[]
  state                       UserState?
  fundTransactions            AdminFundTransaction[]
  notifications               UserNotification[]
  aiBotSubscriptions          AiBotSubscription[]
  aiBotSponsorIncomeReceived  AiBotSponsorIncome[]         @relation("AiBotIncomeSponsor")
  aiBotSponsorIncomeGenerated AiBotSponsorIncome[]         @relation("AiBotIncomeBuyer")
  aiBotSponsorIncomeAuditLogs AiBotSponsorIncomeAuditLog[] @relation("AiBotIncomeAuditSponsor")
  createdBanners              Banner[]                     @relation("BannerCreator")
  bannerAuditLogs             BannerAuditLog[]             @relation("BannerAuditAdmin")
  aiTradeIntents              AiTradeIntent[]
  portfolioSnapshots          PortfolioSnapshot[]
  referralDistributions       ReferralDistribution[]       @relation("ReferralSource")
  referralIncomeEntries       ReferralIncomeEntry[]        @relation("ReferralRecipient")
  referralIncomeAuditLogs     ReferralIncomeAuditLog[]     @relation("ReferralAuditRecipient")
  preferences                 UserPreference?
  supportTickets              SupportTicket[]
  supportChatSessions         ChatSession[]
  supportRestrictions         SupportChatRestriction?
  supportAuditLogsPerformed   SupportAuditLog[]            @relation("SupportAuditAdmin")
  supportAuditLogsTargeted    SupportAuditLog[]            @relation("SupportAuditTarget")
  supportUnmatchedQueries     SupportUnmatchedQuery[]
  nowPaymentsDeposits         NowPaymentsDeposit[]

  @@index([sponsorId])
  @@index([sponsorUid])
}

model NowPaymentsDeposit {
  id                String   @id @default(cuid())
  paymentId         String   @unique
  userId            String
  orderId           String   @unique
  idempotencyKey    String
  usdtAmount        Decimal  @db.Decimal(24, 8)
  requestedAmount   Decimal  @db.Decimal(18, 2)
  walletAddress     String
  txHash             String?
  status             String
  providerStatus     String
  credited           Boolean  @default(false)
  expiresAt          DateTime?
  confirmedAt        DateTime?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  user               User     @relation(fields: [userId], references: [id], onDelete: Restrict)

  @@unique([userId, idempotencyKey])
  @@index([userId, createdAt])
  @@index([status, createdAt])
}

model UserPreference {
  id                 String   @id @default(cuid())
  userId             String   @unique
  emailNotifications Boolean  @default(true)
  pushNotifications  Boolean  @default(true)
  tradeNotifications Boolean  @default(true)
  user               User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

model SupportTicket {
  id         String   @id @default(cuid())
  userId     String
  subject    String
  category   String
  message    String
  status     String   @default("OPEN")
  adminReply String?
  priority   String   @default("NORMAL")
  sessionId  String?
  attachmentName     String?
  attachmentMimeType String?
  attachmentSize     Int?
  attachmentData     Bytes?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  session    ChatSession? @relation(fields: [sessionId], references: [id], onDelete: SetNull)
  replies    SupportReply[]

  @@index([userId, createdAt])
  @@index([userId, updatedAt, id])
  @@index([status, updatedAt])
  @@index([status, updatedAt, id])
  @@index([sessionId, createdAt])
}

model ChatSession {
  id            String        @id @default(cuid())
  userId        String
  title         String        @default("New conversation")
  unreadCount   Int           @default(0)
  lastMessageAt DateTime      @default(now())
  deletedAt     DateTime?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  user          User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages      ChatMessage[]
  tickets       SupportTicket[]

  @@index([userId, deletedAt, lastMessageAt])
  @@index([userId, deletedAt, lastMessageAt, id])
  @@index([unreadCount, lastMessageAt])
}

model ChatMessage {
  id             String      @id @default(cuid())
  conversationId String
  role           String
  message        String
  idempotencyKey String?     @unique
  matchedIntent  String?
  supportRuleId  String?
  matchScore     Float?
  createdAt      DateTime    @default(now())
  conversation   ChatSession @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  supportRule    SupportRule? @relation(fields: [supportRuleId], references: [id], onDelete: SetNull)

  @@index([conversationId, createdAt])
  @@index([conversationId, createdAt, id])
  @@index([supportRuleId, createdAt])
  @@index([createdAt])
}

model SupportReply {
  id        String        @id @default(cuid())
  ticketId  String
  adminId   String
  message   String
  createdAt DateTime      @default(now())
  ticket    SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  @@index([ticketId, createdAt])
  @@index([adminId, createdAt])
}

model SupportChatRestriction {
  id        String   @id @default(cuid())
  userId    String   @unique
  banned    Boolean  @default(false)
  reason    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([banned, updatedAt])
}

model SupportAuditLog {
  id            String   @id @default(cuid())
  adminUserId   String
  targetUserId  String
  chatSessionId String?
  ticketId      String?
  action        String
  metadata      Json?
  createdAt     DateTime @default(now())
  admin         User     @relation("SupportAuditAdmin", fields: [adminUserId], references: [id], onDelete: Restrict)
  target        User     @relation("SupportAuditTarget", fields: [targetUserId], references: [id], onDelete: Restrict)

  @@index([adminUserId, createdAt, id])
  @@index([targetUserId, createdAt, id])
  @@index([chatSessionId, createdAt, id])
  @@index([ticketId, createdAt, id])
}

model SupportRule {
  id             String   @id @default(cuid())
  intentKey      String   @unique
  category       String
  title          String
  response       String
  keywordsJson   Json
  examplesJson   Json
  followUpsJson  Json
  priority       Int      @default(0)
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  messages       ChatMessage[]
  resolvedQueries SupportUnmatchedQuery[]

  @@index([isActive, priority, intentKey])
  @@index([category, isActive, priority])
}

model SupportUnmatchedQuery {
  id                String       @id @default(cuid())
  userId            String
  message           String
  normalizedMessage String
  resolvedRuleId    String?
  status            String       @default("OPEN")
  createdAt         DateTime     @default(now())
  user              User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  resolvedRule      SupportRule? @relation(fields: [resolvedRuleId], references: [id], onDelete: SetNull)

  @@index([status, createdAt, id])
  @@index([userId, createdAt, id])
  @@index([resolvedRuleId, createdAt])
}

model SupportConfiguration {
  id            String   @id @default("default")
  supportEmail  String?
  whatsappUrl   String?
  telegramUrl   String?
  helpCenterUrl String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model ReferralDistribution {
  id               String                     @id @default(cuid())
  referredUserId   String
  eventType        String                     @default("FIRST_SPOT_TO_FUTURE")
  sourceTransferId String                     @unique
  idempotencyKey   String                     @unique
  transferAmount   Decimal                    @db.Decimal(18, 2)
  status           ReferralDistributionStatus
  resultCode       String
  createdAt        DateTime                   @default(now())
  referredUser     User                       @relation("ReferralSource", fields: [referredUserId], references: [id], onDelete: Restrict)
  entries          ReferralIncomeEntry[]

  @@unique([referredUserId, eventType])
  @@index([referredUserId, createdAt])
}

model ReferralIncomeEntry {
  id                   String               @id @default(cuid())
  distributionId       String
  recipientUserId      String
  sourceReferredUserId String
  sourceTransferId     String
  level                Int
  incomeType           String
  percentage           Decimal              @db.Decimal(5, 2)
  amount               Decimal              @db.Decimal(18, 2)
  transactionType      String
  ledgerTransactionId  String               @unique
  createdAt            DateTime             @default(now())
  distribution         ReferralDistribution @relation(fields: [distributionId], references: [id], onDelete: Restrict)
  recipient            User                 @relation("ReferralRecipient", fields: [recipientUserId], references: [id], onDelete: Restrict)

  @@unique([distributionId, recipientUserId, incomeType, level])
  @@index([recipientUserId, createdAt])
  @@index([sourceReferredUserId, sourceTransferId])
}

model ReferralIncomeAuditLog {
  id                   String   @id @default(cuid())
  distributionId       String
  recipientUserId      String
  sourceReferredUserId String
  level                Int
  action               String
  ledgerTransactionId  String   @unique
  metadata             Json?
  createdAt            DateTime @default(now())
  recipient            User     @relation("ReferralAuditRecipient", fields: [recipientUserId], references: [id], onDelete: Restrict)

  @@index([distributionId, createdAt])
  @@index([recipientUserId, createdAt])
}

model PortfolioSnapshot {
  id            String   @id @default(cuid())
  userId        String
  localDate     String   @db.VarChar(10)
  timezone      String
  spotBalance   Decimal  @db.Decimal(18, 2)
  futureBalance Decimal  @db.Decimal(18, 2)
  totalBalance  Decimal  @db.Decimal(18, 2)
  createdAt     DateTime @default(now())
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, localDate])
  @@index([userId, localDate])
}

model AiTradeIntent {
  id        String    @id @default(cuid())
  tokenHash String    @unique
  userId    String
  sessionId String
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, sessionId])
  @@index([expiresAt])
}

model Banner {
  id               String           @id @default(cuid())
  title            String
  imageUrl         String
  imagePath        String
  mimeType         String
  fileSize         Int
  width            Int
  height           Int
  status           BannerStatus     @default(DRAFT)
  isActive         Boolean          @default(false)
  startsAt         DateTime?
  expiresAt        DateTime?
  createdByAdminId String
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  createdByAdmin   User             @relation("BannerCreator", fields: [createdByAdminId], references: [id], onDelete: Restrict)
  auditLogs        BannerAuditLog[]

  @@index([isActive, startsAt, expiresAt])
  @@index([createdAt])
}

model BannerAuditLog {
  id        String   @id @default(cuid())
  bannerId  String?
  adminId   String
  action    String
  metadata  Json?
  createdAt DateTime @default(now())
  banner    Banner?  @relation(fields: [bannerId], references: [id], onDelete: SetNull)
  admin     User     @relation("BannerAuditAdmin", fields: [adminId], references: [id], onDelete: Restrict)

  @@index([bannerId, createdAt])
  @@index([adminId, createdAt])
}

model AiBotSubscription {
  id                    String                  @id @default(cuid())
  userId                String
  price                 Decimal                 @db.Decimal(18, 2)
  status                AiBotSubscriptionStatus @default(ACTIVE)
  activatedAt           DateTime
  expiresAt             DateTime
  purchaseTransactionId String                  @unique
  createdAt             DateTime                @default(now())
  updatedAt             DateTime                @updatedAt
  user                  User                    @relation(fields: [userId], references: [id], onDelete: Cascade)
  sponsorIncome         AiBotSponsorIncome?

  @@index([userId, activatedAt])
  @@index([userId, expiresAt])
}

model AiBotSponsorIncome {
  id                       String                      @id @default(cuid())
  sponsorUserId            String
  buyerUserId              String
  botSubscriptionId        String                      @unique
  botPurchaseTransactionId String                      @unique
  purchaseAmount           Decimal                     @db.Decimal(18, 2)
  percentage               Decimal                     @db.Decimal(5, 2)
  commissionAmount         Decimal                     @db.Decimal(18, 2)
  ledgerTransactionId      String                      @unique
  status                   String                      @default("COMPLETED")
  createdAt                DateTime                    @default(now())
  sponsor                  User                        @relation("AiBotIncomeSponsor", fields: [sponsorUserId], references: [id], onDelete: Restrict)
  buyer                    User                        @relation("AiBotIncomeBuyer", fields: [buyerUserId], references: [id], onDelete: Restrict)
  subscription             AiBotSubscription           @relation(fields: [botSubscriptionId], references: [id], onDelete: Restrict)
  auditLog                 AiBotSponsorIncomeAuditLog?

  @@index([sponsorUserId, createdAt])
  @@index([buyerUserId, createdAt])
}

model AiBotSponsorIncomeAuditLog {
  id                  String             @id @default(cuid())
  sponsorIncomeId     String             @unique
  sponsorUserId       String
  action              String
  ledgerTransactionId String             @unique
  metadata            Json
  createdAt           DateTime           @default(now())
  sponsorIncome       AiBotSponsorIncome @relation(fields: [sponsorIncomeId], references: [id], onDelete: Restrict)
  sponsor             User               @relation("AiBotIncomeAuditSponsor", fields: [sponsorUserId], references: [id], onDelete: Restrict)

  @@index([sponsorUserId, createdAt])
}

model AdminFundTransaction {
  id                  String   @id @default(cuid())
  idempotencyKey      String   @unique
  userId              String
  userUid             String   @db.VarChar(8)
  userName            String
  action              String
  amount              Decimal  @db.Decimal(18, 2)
  reason              String
  adminId             String
  adminUid            String   @db.VarChar(8)
  previousBalance     Decimal  @db.Decimal(18, 2)
  newBalance          Decimal  @db.Decimal(18, 2)
  ledgerTransactionId String   @unique
  status              String
  createdAt           DateTime @default(now())
  user                User     @relation(fields: [userId], references: [id], onDelete: Restrict)

  @@index([userUid, createdAt])
  @@index([adminId, createdAt])
}

model UserNotification {
  id        String   @id @default(cuid())
  userId    String
  title     String
  message   String
  type      String
  read      Boolean  @default(false)
  reference String   @unique
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}

model UserState {
  id        String   @id @default(cuid())
  userId    String   @unique
  wallet    Json
  trading   Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@unique([identifier, token])
}

model IdempotencyRecord {
  id           String            @id @default(cuid())
  key          String
  scope        String
  userId       String?
  requestHash  String?
  responseData Json?
  status       IdempotencyStatus @default(PENDING)
  createdAt    DateTime          @default(now())
  expiresAt    DateTime?
  user         User?             @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@unique([key, scope])
  @@index([userId])
  @@index([expiresAt])
}
