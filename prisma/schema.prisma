generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  USER
  ADMIN
}

enum IdempotencyStatus {
  PENDING
  COMPLETED
  FAILED
}

model User {
  id             String              @id @default(cuid())
  uid            String              @unique @db.VarChar(8)
  email          String              @unique
  passwordHash   String
  name           String
  role           Role                @default(USER)
  sponsorId      String?
  sponsorUid     String?             @db.VarChar(8)
  emailVerified  DateTime?
  image          String?
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt
  sponsor        User?               @relation("UserSponsor", fields: [sponsorId], references: [id], onDelete: SetNull)
  directReferrals User[]              @relation("UserSponsor")
  accounts       Account[]
  sessions       Session[]
  idempotencyRecords IdempotencyRecord[]
  state          UserState?
  fundTransactions AdminFundTransaction[]
  notifications UserNotification[]

  @@index([sponsorId])
  @@index([sponsorUid])
}

model AdminFundTransaction {
  id                  String   @id @default(cuid())
  idempotencyKey      String   @unique
  userId              String
  userUid             String   @db.VarChar(8)
  userName            String
  action              String
  amount              Decimal  @db.Decimal(18, 2)
  reason              String
  adminId             String
  adminUid            String   @db.VarChar(8)
  previousBalance     Decimal  @db.Decimal(18, 2)
  newBalance          Decimal  @db.Decimal(18, 2)
  ledgerTransactionId String   @unique
  status              String
  createdAt           DateTime @default(now())
  user                User     @relation(fields: [userId], references: [id], onDelete: Restrict)

  @@index([userUid, createdAt])
  @@index([adminId, createdAt])
}

model UserNotification {
  id        String   @id @default(cuid())
  userId    String
  title     String
  message   String
  type      String
  read      Boolean  @default(false)
  reference String   @unique
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}

model UserState {
  id        String   @id @default(cuid())
  userId    String   @unique
  wallet    Json
  trading   Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@unique([identifier, token])
}

model IdempotencyRecord {
  id           String            @id @default(cuid())
  key          String
  scope        String
  userId       String?
  requestHash  String?
  responseData Json?
  status       IdempotencyStatus @default(PENDING)
  createdAt    DateTime          @default(now())
  expiresAt    DateTime?
  user         User?             @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@unique([key, scope])
  @@index([userId])
  @@index([expiresAt])
}
