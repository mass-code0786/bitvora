generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  USER
  ADMIN
}

enum IdempotencyStatus {
  PENDING
  COMPLETED
  FAILED
}

enum AiBotSubscriptionStatus {
  ACTIVE
  EXPIRED
}

enum BannerStatus {
  DRAFT
  ACTIVE
  INACTIVE
  EXPIRED
}

enum ReferralDistributionStatus {
  CREATED
  NO_PAYOUT
}

model User {
  id                 String                 @id @default(cuid())
  uid                String                 @unique @db.VarChar(8)
  email              String                 @unique
  passwordHash       String
  name               String
  role               Role                   @default(USER)
  sponsorId          String?
  sponsorUid         String?                @db.VarChar(8)
  emailVerified      DateTime?
  image              String?
  createdAt          DateTime               @default(now())
  updatedAt          DateTime               @updatedAt
  timezone           String                 @default("UTC")
  sponsor            User?                  @relation("UserSponsor", fields: [sponsorId], references: [id], onDelete: SetNull)
  directReferrals    User[]                 @relation("UserSponsor")
  accounts           Account[]
  sessions           Session[]
  idempotencyRecords IdempotencyRecord[]
  state              UserState?
  fundTransactions   AdminFundTransaction[]
  notifications      UserNotification[]
  aiBotSubscriptions AiBotSubscription[]
  createdBanners      Banner[]               @relation("BannerCreator")
  bannerAuditLogs     BannerAuditLog[]        @relation("BannerAuditAdmin")
  aiTradeIntents      AiTradeIntent[]
  portfolioSnapshots  PortfolioSnapshot[]
  referralDistributions ReferralDistribution[] @relation("ReferralSource")
  referralIncomeEntries ReferralIncomeEntry[] @relation("ReferralRecipient")
  referralIncomeAuditLogs ReferralIncomeAuditLog[] @relation("ReferralAuditRecipient")

  @@index([sponsorId])
  @@index([sponsorUid])
}

model ReferralDistribution {
  id                 String                     @id @default(cuid())
  referredUserId     String
  eventType          String                     @default("FIRST_SPOT_TO_FUTURE")
  sourceTransferId   String                     @unique
  idempotencyKey     String                     @unique
  transferAmount     Decimal                    @db.Decimal(18, 2)
  status             ReferralDistributionStatus
  resultCode         String
  createdAt          DateTime                   @default(now())
  referredUser       User                       @relation("ReferralSource", fields: [referredUserId], references: [id], onDelete: Restrict)
  entries            ReferralIncomeEntry[]

  @@unique([referredUserId, eventType])
  @@index([referredUserId, createdAt])
}

model ReferralIncomeEntry {
  id                 String               @id @default(cuid())
  distributionId     String
  recipientUserId    String
  sourceReferredUserId String
  sourceTransferId   String
  level              Int
  percentage         Decimal              @db.Decimal(5, 2)
  amount             Decimal              @db.Decimal(18, 2)
  transactionType    String
  ledgerTransactionId String               @unique
  createdAt          DateTime              @default(now())
  distribution       ReferralDistribution @relation(fields: [distributionId], references: [id], onDelete: Restrict)
  recipient          User                 @relation("ReferralRecipient", fields: [recipientUserId], references: [id], onDelete: Restrict)

  @@unique([distributionId, recipientUserId, level])
  @@index([recipientUserId, createdAt])
  @@index([sourceReferredUserId, sourceTransferId])
}

model ReferralIncomeAuditLog {
  id                 String   @id @default(cuid())
  distributionId     String
  recipientUserId    String
  sourceReferredUserId String
  level              Int
  action             String
  ledgerTransactionId String  @unique
  metadata           Json?
  createdAt          DateTime @default(now())
  recipient          User     @relation("ReferralAuditRecipient", fields: [recipientUserId], references: [id], onDelete: Restrict)

  @@index([distributionId, createdAt])
  @@index([recipientUserId, createdAt])
}

model PortfolioSnapshot {
  id            String   @id @default(cuid())
  userId        String
  localDate     String   @db.VarChar(10)
  timezone      String
  spotBalance   Decimal  @db.Decimal(18, 2)
  futureBalance Decimal  @db.Decimal(18, 2)
  totalBalance  Decimal  @db.Decimal(18, 2)
  createdAt     DateTime @default(now())
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, localDate])
  @@index([userId, localDate])
}

model AiTradeIntent {
  id        String   @id @default(cuid())
  tokenHash String   @unique
  userId    String
  sessionId String
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, sessionId])
  @@index([expiresAt])
}

model Banner {
  id               String           @id @default(cuid())
  title            String
  imageUrl         String
  imagePath        String
  mimeType         String
  fileSize         Int
  width            Int
  height           Int
  status           BannerStatus     @default(DRAFT)
  isActive         Boolean          @default(false)
  startsAt         DateTime?
  expiresAt        DateTime?
  createdByAdminId String
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  createdByAdmin   User             @relation("BannerCreator", fields: [createdByAdminId], references: [id], onDelete: Restrict)
  auditLogs        BannerAuditLog[]

  @@index([isActive, startsAt, expiresAt])
  @@index([createdAt])
}

model BannerAuditLog {
  id        String   @id @default(cuid())
  bannerId  String?
  adminId   String
  action    String
  metadata  Json?
  createdAt DateTime @default(now())
  banner    Banner?  @relation(fields: [bannerId], references: [id], onDelete: SetNull)
  admin     User     @relation("BannerAuditAdmin", fields: [adminId], references: [id], onDelete: Restrict)

  @@index([bannerId, createdAt])
  @@index([adminId, createdAt])
}

model AiBotSubscription {
  id                    String                  @id @default(cuid())
  userId                String
  price                 Decimal                 @db.Decimal(18, 2)
  status                AiBotSubscriptionStatus @default(ACTIVE)
  activatedAt           DateTime
  expiresAt             DateTime
  purchaseTransactionId String                  @unique
  createdAt             DateTime                @default(now())
  updatedAt             DateTime                @updatedAt
  user                  User                    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, activatedAt])
  @@index([userId, expiresAt])
}

model AdminFundTransaction {
  id                  String   @id @default(cuid())
  idempotencyKey      String   @unique
  userId              String
  userUid             String   @db.VarChar(8)
  userName            String
  action              String
  amount              Decimal  @db.Decimal(18, 2)
  reason              String
  adminId             String
  adminUid            String   @db.VarChar(8)
  previousBalance     Decimal  @db.Decimal(18, 2)
  newBalance          Decimal  @db.Decimal(18, 2)
  ledgerTransactionId String   @unique
  status              String
  createdAt           DateTime @default(now())
  user                User     @relation(fields: [userId], references: [id], onDelete: Restrict)

  @@index([userUid, createdAt])
  @@index([adminId, createdAt])
}

model UserNotification {
  id        String   @id @default(cuid())
  userId    String
  title     String
  message   String
  type      String
  read      Boolean  @default(false)
  reference String   @unique
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}

model UserState {
  id        String   @id @default(cuid())
  userId    String   @unique
  wallet    Json
  trading   Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@unique([identifier, token])
}

model IdempotencyRecord {
  id           String            @id @default(cuid())
  key          String
  scope        String
  userId       String?
  requestHash  String?
  responseData Json?
  status       IdempotencyStatus @default(PENDING)
  createdAt    DateTime          @default(now())
  expiresAt    DateTime?
  user         User?             @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@unique([key, scope])
  @@index([userId])
  @@index([expiresAt])
}
